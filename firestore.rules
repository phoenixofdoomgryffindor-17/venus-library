
rules_version = '2';

// IMPORTANT: A composite index is required for the author dashboard query.
// Please create it in your Firebase console.
//
// Collection: books
// Fields:
// 1. authorId (Ascending)
// 2. updatedAt (Descending)
//
// You can use this link to create it directly:
// https://console.firebase.google.com/v1/r/project/studio-949069045-2e576/firestore/indexes?create_composite=ClRwcm9qZWN0cy9zdHVkaW8tOTQ5MDY5MDQ1LTJlNTc2L2RhdGFiYXNlcy8oZGVmYXVsdCkvY29sbGVjdGlvbkdyb3Vwcy9ib29rcy9pbmRleGVzL18QARoMCghhdXRob3JJZBABGg0KCXVwZGF0ZWRBdBACGgwKCF9fbmFtZV9fEAI

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
